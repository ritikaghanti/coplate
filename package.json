{
  "name": "coplate",
  "private": true,
  "version": "0.1.0",
  "description": "Coplate — snap a photo of your plate, get your macros.",
  "scripts": {
    "dev:api": "pnpm --filter @coplate/api dev",
    "dev:mobile": "pnpm --filter @coplate/mobile start",
    "db:push": "pnpm --filter @coplate/api db:push",
    "db:studio": "pnpm --filter @coplate/api db:studio",
    "eval": "pnpm --filter @coplate/api eval",
    "build:shared": "pnpm --filter @coplate/shared build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "expo-constants": "18.0.13"
    }
  }
}
